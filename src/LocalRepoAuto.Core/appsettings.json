{
  "RepositorySettings": {
    "RepositoryPath": ".",
    "GitTimeout": 30000,
    "LogOperations": true
  },
  "Staleness": {
    "ThresholdDays": 30,
    "ProtectedBranches": [
      "main",
      "master",
      "develop",
      "staging",
      "production"
    ],
    "PatternPenalties": {
      "wip/": 25,
      "temp/": 20,
      "experiment/": 15,
      "feature/old-": 10
    },
    "AuthorInactivityDays": 90
  },
  "ConflictDetection": {
    "EnableDryRun": true,
    "ParseDeepSemantics": false,
    "MaxConflictSize": 10000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "LocalRepoAuto": "Debug"
    }
  }
}
